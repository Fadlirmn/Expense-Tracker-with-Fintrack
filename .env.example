# Groq API Key untuk LLM (Pendidikan / Ekstraksi / Analisis)
GROQ_API_KEY="YOUR_GROQ_API_KEY_HERE"

# Telegram Bot Token dari @BotFather
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN_HERE"

# Daftar ID Telegram Anda untuk Whitelist Keamanan (dipisahkan dengan koma)
# Hubungi @userinfobot di Telegram untuk mencari tahu ID Telegram Anda
ALLOWED_TELEGRAM_USER_IDS="USER_ID_1,USER_ID_2"

# --- FINTRACK INTEGRATION CONFIG ---
# URL API internal container FinTrack (gunakan http://fintrack-api:8080 di Docker, atau http://localhost:8080 di localhost)
FINTRACK_API_URL="http://fintrack-api:8080"

# Harus cocok dengan GATEWAY_API_KEY di FinTrack
FINTRACK_API_KEY="YOUR_FINTRACK_GATEWAY_API_KEY_HERE"

# UUID User FinTrack untuk sinkronisasi otomatis via Streamlit Dashboard (opsional)
DEFAULT_FINTRACK_USER_ID="YOUR_FINTRACK_USER_UUID_HERE"
